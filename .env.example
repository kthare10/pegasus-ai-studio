# PegasusAI Studio — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env

# LLM Provider (required)
# Options: anthropic, openai, fabric, nrp, custom, ollama
LLM_PROVIDER=anthropic

# Model (optional — uses provider default if not set)
# LLM_MODEL=claude-sonnet-4-5-20250929

# API Keys (set the one matching your provider)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# FABRIC_AI_API_KEY=
# NRP_API_KEY=

# Custom endpoint (only if LLM_PROVIDER=custom)
# CUSTOM_BASE_URL=https://your-endpoint.com/v1
# CUSTOM_API_KEY=

# Ollama (only if LLM_PROVIDER=ollama)
# OLLAMA_HOST=http://localhost:11434
