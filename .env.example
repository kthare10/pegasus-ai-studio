# Pegasus AI Workbench — Environment Variables
# Copy this file to .env and fill in the values you need.
# API keys are NEVER baked into the image — they must be injected at runtime.
#
# Quick start:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your API key(s) below
#   3. Run:  docker compose up
#
# Or use the LLM_Setup.ipynb notebook or `pegasus-ai-setup` wizard inside
# the container to configure providers interactively.
#
# You can configure MULTIPLE providers — all configured providers will
# appear in OpenCode and other AI tools for model selection.

# ── Default Provider ─────────────────────────────────────────────
# Set LLM_PROVIDER to one of: anthropic, openai, fabric, nrp, custom, ollama
# This is the default for tools that need a single provider (Jupyter AI).
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI ────────────────────────────────────────────────────
# OPENAI_API_KEY=

# ── FABRIC AI ───────────────────────────────────────────────────
# FABRIC AI gateway (OpenAI-compatible) at https://ai.fabric-testbed.net/v1
# FABRIC_AI_API_KEY=

# ── NRP (Nautilus) ──────────────────────────────────────────────
# NRP eLLM gateway (OpenAI-compatible) at https://ellm.nrp-nautilus.io/v1
# NRP_API_KEY=

# ── Custom OpenAI-compatible endpoint ─────────────────────────
# For institutional / self-hosted LLMs (vLLM, TGI, LiteLLM, etc.)
# CUSTOM_BASE_URL=https://llm.university.edu/v1
# CUSTOM_API_KEY=inst-key-xxxxx

# ── Ollama (local inference) ──────────────────────────────────
# OLLAMA_HOST=http://host.docker.internal:11434

# ── Jupyter ───────────────────────────────────────────────────
# Set a fixed token for JupyterLab access (leave blank for auto-generated)
# JUPYTER_TOKEN=
