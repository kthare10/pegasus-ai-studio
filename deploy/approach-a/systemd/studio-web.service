[Unit]
Description=PegasusAI Studio Web (shared Next.js frontend)
After=network.target

[Service]
User=studio-web
Group=studio-web
Environment=PORT=3000
Environment=HOSTNAME=127.0.0.1
Environment=NODE_ENV=production
WorkingDirectory=/opt/pegasus-studio/web
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
