# ── Secrets / local environment ──────────────────────────────
.env
.env.*
!.env.example

# Auth secrets & TLS material (templates/scripts are kept)
auth/vouch/config.yaml
auth/ssl/*.pem
auth/ssl/*.key
auth/ssl/*.crt

# Local Claude Code settings
.claude/settings.local.json

# ── Studio runtime workspace — never push (DBs, runs, user data) ──
work/

