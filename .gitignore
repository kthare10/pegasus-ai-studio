__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Node / Next.js ───────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-error.log*

# ── OS / editor ──────────────────────────────────────────────
.DS_Store
*.swp
